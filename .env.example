# ─── Database (Docker Compose) ───────────────────────────────────────────────
DB_USER=refunction
DB_PASSWORD=rehab_secret
DB_NAME=refunction_rehab
DB_PORT=5432

# Set automatically inside Docker Compose (server reads this).
# For cloud managed DB (Supabase/Neon/Railway/RDS), override this value only.
DATABASE_URL=postgresql://refunction:rehab_secret@db:5432/refunction_rehab

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_min_32_chars

# ─── Razorpay (leave empty to skip payment gateway) ──────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@refunctionrehab.com

# ─── Cloudinary (patient documents) ──────────────────────────────────────────
CLOUDINARY_URL=

# ─── Twilio WhatsApp ──────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
WHATSAPP_COUNTRY_CODE=+91
WHATSAPP_ENABLED=false

# Doctor/clinic number that receives new-booking alerts. 10-digit local number;
# country code is taken from WHATSAPP_COUNTRY_CODE. Leave empty to disable.
CLINIC_WHATSAPP_TO=

# Approved Twilio Content template SID for the booking alert (with Confirm /
# Suggest-a-slot quick-reply buttons). Leave empty to fall back to a plain text body.
TWILIO_BOOKING_CONTENT_SID=

# ─── Fast2SMS (SMS Gateway) ─────────────────────────────────────────────────
FAST2SMS_API_KEY=
SMS_ENABLED=false
SMS_SENDER_ID=RFREHB
SMS_ROUTE=dlt

# ─── Frontend (Vite build-time) ───────────────────────────────────────────────
VITE_API_URL=http://localhost:4000
